import React from 'react';
import styled from '@emotion/styled';
import Layout from '../components/Layout';
import CustomSearchInput from '../components/CustomSearch/CustomSearchInput';

const SearchTestPage = () => {
  return (
    <Layout>
      <Container>
        <Header>
          <Title>Search Test</Title>
          <Subtitle>Test the new search functionality</Subtitle>
        </Header>

        <SearchSection>
          <SearchInputWrapper>
            <CustomSearchInput 
              placeholder="Search documentation..." 
              showShortcut={true}
            />
          </SearchInputWrapper>
          <HelpText>
            Click the search box above or press <kbd>Cmd/Ctrl + K</kbd> to open search
          </HelpText>
        </SearchSection>
      </Container>
    </Layout>
  );
};

// Styled Components
const Container = styled.div`
  max-width: 800px;
  margin: 0 auto;
  padding: 4rem 2rem;
`;

const Header = styled.div`
  text-align: center;
  margin-bottom: 4rem;
`;

const Title = styled.h1`
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
  color: var(--primary-text-color);
`;

const Subtitle = styled.p`
  font-size: 1.125rem;
  color: var(--secondary-text-color);
  margin: 0;
`;

const SearchSection = styled.div`
  text-align: center;
`;

const SearchInputWrapper = styled.div`
  max-width: 500px;
  margin: 0 auto 1rem auto;
  display: flex;
  justify-content: center;
`;

const HelpText = styled.p`
  color: var(--secondary-text-color);
  font-size: 0.875rem;
  
  kbd {
    background: var(--tertiary-background-color);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
    font-family: monospace;
    border: 1px solid var(--border-color);
  }
`;

export default SearchTestPage;